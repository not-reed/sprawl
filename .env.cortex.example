# Cortex — Crypto market intelligence daemon
# Copy to .env.cortex and fill in required values

# ── Required ─────────────────────────────────────────────────────────────────

# OpenRouter API key — used for observer/reflector LLM calls, signal generation,
# and embedding generation. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Recommended ──────────────────────────────────────────────────────────────

# CryptoPanic API key — aggregates 20+ crypto news sources with sentiment tags.
# Without this, cortex falls back to RSS (CoinDesk + CoinTelegraph), which has
# less coverage and no sentiment data. Free tier is fine.
# Sign up at https://cryptopanic.com/developers/api/
#CRYPTOPANIC_API_KEY=

# CryptoCompare API key — structured news with coin tagging.
# Free tier works without key (lower rate limit). Key increases limits.
# Sign up at https://min-api.cryptocompare.com/
#CRYPTOCOMPARE_API_KEY=

# ── Optional (sensible defaults) ─────────────────────────────────────────────

# Comma-separated CoinGecko token IDs. Full list: https://api.coingecko.com/api/v3/coins/list
# Default: bitcoin,ethereum
#TRACKED_TOKENS=bitcoin,ethereum,solana,ripple

# SQLite database path. Created automatically.
# Default: ./data/cortex.db
#DATABASE_URL=./data/cortex.db

# LLM model for observer/reflector/signal generation (via OpenRouter).
# Default: google/gemini-3-flash-preview
#MEMORY_WORKER_MODEL=google/gemini-3-flash-preview

# Embedding model (via OpenRouter). Default: qwen/qwen3-embedding-4b
#EMBEDDING_MODEL=qwen/qwen3-embedding-4b

# ── Intervals (seconds) ─────────────────────────────────────────────────────

# How often to fetch prices. Default: 300 (5 min).
# CoinGecko free tier allows 10-30 calls/min, so don't go below 60.
#PRICE_INTERVAL=300

# How often to fetch news. Default: 900 (15 min).
#NEWS_INTERVAL=900

# How often to generate trading signals. Default: 3600 (1 hour).
# Each cycle makes 1 LLM call per tracked token.
#SIGNAL_INTERVAL=3600

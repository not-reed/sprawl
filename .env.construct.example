# Construct — AI braindump companion
# Copy to .env.construct and fill in required values

# ── Required ─────────────────────────────────────────────────────────────────

OPENROUTER_API_KEY=sk-or-...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Recommended ──────────────────────────────────────────────────────────────

# Web search (free tier: 1000 searches/month)
#TAVILY_API_KEY=tvly-...

# ── Optional (sensible defaults) ─────────────────────────────────────────────

# LLM model (via OpenRouter). Default: google/gemini-3-flash-preview
#OPENROUTER_MODEL=google/gemini-3-flash-preview

# SQLite database path. Created automatically.
#DATABASE_URL=./data/construct.db

# Comma-separated Telegram user IDs allowed to interact
#ALLOWED_TELEGRAM_IDS=123456,789012

# Agent timezone. Default: UTC
#TIMEZONE=UTC

# Logging
#LOG_LEVEL=info
#LOG_FILE=./data/construct.log

# Scope for self-edit tools. Default: .
#PROJECT_ROOT=.

# Extensions directory (default: ./data in dev, $XDG_DATA_HOME/construct in prod)
#EXTENSIONS_DIR=./data

# Embedding model (via OpenRouter). Default: qwen/qwen3-embedding-4b
#EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# Dedicated model for memory workers (observer, reflector, graph)
#MEMORY_WORKER_MODEL=qwen/qwen3.5-flash-02-23

# Extension secrets — any EXT_* vars are synced to the secrets table on startup
#EXT_OPENWEATHERMAP_API_KEY=abc123

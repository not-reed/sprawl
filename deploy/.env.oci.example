# OCI API credentials (from ~/.oci/config or OCI console)
OCI_USER=ocid1.user.oc1..aaaaaaa
OCI_TENANCY=ocid1.tenancy.oc1..aaaaaaa
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_REGION=us-ashburn-1
OCI_KEY_FILE=~/.oci/oci_api_key.pem

# SSH key for instance access
OCI_SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub
# Or inline: OCI_SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# Instance config (defaults shown)
# OCI_INSTANCE_NAME=construct
# OCI_OCPUS=1
# OCI_MEMORY_GB=6
# OCI_BOOT_VOLUME_GB=50
# OCI_OS=Canonical Ubuntu
# OCI_OS_VERSION=24.04

# Auto-discovered if empty (recommended)
# OCI_AVAILABILITY_DOMAIN=
# OCI_SUBNET_ID=
# OCI_IMAGE_ID=

# Retry interval in seconds (default: 60)
# OCI_RETRY_INTERVAL_SECS=60

# Telegram notification on success (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

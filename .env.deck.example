# Deck — Memory graph explorer
# Copy to .env.deck and adjust as needed

# SQLite database to browse (any cairn-enabled DB)
#DATABASE_URL=./data/construct.db

# OpenRouter API key (for embedding-based search)
#OPENROUTER_API_KEY=sk-or-...

# Embedding model. Default: qwen/qwen3-embedding-4b
#EMBEDDING_MODEL=qwen/qwen3-embedding-4b

# Server port. Default: 4800
#PORT=4800

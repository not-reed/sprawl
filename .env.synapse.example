# Synapse — Paper trading daemon
# Copy to .env.synapse and adjust as needed

# ── Database paths ───────────────────────────────────────────────────────────

# Cortex DB to read signals from
#CORTEX_DATABASE_URL=./data/cortex.db

# Synapse DB (positions, trades, portfolio state)
#DATABASE_URL=./data/synapse.db

# ── Portfolio ────────────────────────────────────────────────────────────────

#INITIAL_BALANCE_USD=10000

# ── Loop intervals (seconds) ────────────────────────────────────────────────

#POLL_INTERVAL=60
#RISK_CHECK_INTERVAL=30

# ── Signal filtering ────────────────────────────────────────────────────────

#MIN_CONFIDENCE_SHORT=0.4
#MIN_CONFIDENCE_LONG=0.6

# ── Position sizing ─────────────────────────────────────────────────────────

#MIN_TRADE_USD=50
#SIMULATED_GAS_USD=0.50
#MAX_GAS_PCT=2
#MAX_POSITION_PCT=25

# ── Risk management ─────────────────────────────────────────────────────────

#MAX_PORTFOLIO_DRAWDOWN_PCT=15
#STOP_LOSS_PCT=8
#TAKE_PROFIT_PCT=20
#MAX_OPEN_POSITIONS=8

# ── Paper executor ──────────────────────────────────────────────────────────

#SLIPPAGE_BPS=30
